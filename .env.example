# Environment configuration for Neuronal SEO
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://neuronal_seo:neuronal_seo_pass@localhost:5432/neuronal_seo
DATABASE_URL_SYNC=postgresql+psycopg2://neuronal_seo:neuronal_seo_pass@localhost:5432/neuronal_seo

# Redis
REDIS_URL=redis://localhost:6379/0

# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_LLM_MODEL=gpt-4o

# DataForSEO
DATAFORSEO_LOGIN=your-email@example.com
DATAFORSEO_API_KEY=your-dataforseo-api-key

# SerpAPI (alternative)
SERPAPI_KEY=your-serpapi-key

# Local embeddings (if not using OpenAI)
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Report settings
REPORT_OUTPUT_DIR=./reports
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
REPORT_EMAIL_TO=

# Weekly scheduler (set ENABLE_SCHEDULER=true to auto-start with API)
ENABLE_SCHEDULER=false
SCHEDULE_DAY=mon
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0

# Crawler
CRAWLER_USER_AGENT=Mozilla/5.0 (compatible; NeuronalSEO/1.0)
CRAWLER_RATE_LIMIT=2
CRAWLER_MAX_PAGES=500
